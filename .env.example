# ═══════════════════════════════════════════
# ULTRON v3.0 — Environment Variables
# Copy this to .env.local and fill in your keys
# ═══════════════════════════════════════════

# ── E2B Sandbox (REQUIRED) ────────────────
E2B_API_KEY=e2b_xxxx

# ── LLM Providers ─────────────────────────
# Primary: Nvidia NIM
LLM_API_KEY=nvapi-xxxx
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-3.1-405b-instruct

# Fallback: OpenRouter (Claude, Gemini, Llama)
OPENROUTER_API_KEY=sk-or-v1-xxxx

# Direct providers (optional — enables per-agent assignment)
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_AI_API_KEY=xxxx

# ── Air-Gap Mode (OPTIONAL) ──────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5-27b

# ── Database (REQUIRED for persistence) ──
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── pgvector RAG (OPTIONAL) ──────────────
# DATABASE_URL=postgresql://user:pass@host/db

# ── Knowledge Graph (OPTIONAL) ───────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=xxxx

# ── Web Search (at least one recommended) ─
PERPLEXITY_API_KEY=pplx-xxxx
TAVILY_API_KEY=tvly-xxxx
SERPER_API_KEY=xxxx

# ── Admin Authentication ───────────────────
# Admin login credentials (REQUIRED for deployment)
ADMIN_EMAIL=your-email@example.com
ADMIN_PASSWORD_HASH=$2b$12$xxxxx  # Generate with: node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
SESSION_SECRET=your-random-secret-key-here  # openssl rand -hex 32

# ── API Authentication ────────────────────
# Set this to require Bearer token on all API routes
# Leave empty for local development (no auth)
ULTRON_API_KEY=

# ── Observability ─────────────────────────
REPLAY_CHAIN_ENABLED=true

# ── Security ──────────────────────────────
HITL_TIMEOUT_SECONDS=300
