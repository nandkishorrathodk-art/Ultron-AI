# ═══════════════════════════════════════════════════════════
# ULTRON-AI v3.0 — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ─── Authentication (Custom JWT) ───
JWT_SECRET=your-256-bit-secret-key-here
AUTH_SECRET=your-auth-secret-key-here

# ─── Convex (Database & Backend) ───
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOY_KEY=prod:your-deploy-key
CONVEX_SERVICE_ROLE_KEY=your-service-role-key

# ─── AI Providers ───
# Primary: NVIDIA NIM (for pentest-specific models)
NVIDIA_API_KEY=nvapi-your-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Fallback: OpenRouter (multi-model routing)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# OpenAI (for content moderation)
OPENAI_API_KEY=sk-your-key-here

# ─── E2B Sandbox (Code Execution) ───
E2B_API_KEY=e2b_your-key-here

# ─── Stripe (Payments — Optional) ───
STRIPE_SECRET_KEY=sk_test_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-key-here
STRIPE_PRICE_ID_PRO_MONTHLY=price_xxx
STRIPE_PRICE_ID_PRO_YEARLY=price_xxx

# ─── S3 Storage (Optional) ───
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=ultron-ai-files

# ─── Rate Limiting (Optional) ───
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ─── Analytics (Optional) ───
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Trigger.dev (Durable Agent Tasks — Optional) ───
TRIGGER_SECRET_KEY=tr_dev_your-key

# ─── Knowledge Graph (Optional) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# ─── Vector DB (Optional) ───
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-key

# ─── Real-time Streaming (Optional) ───
CENTRIFUGO_URL=ws://localhost:8000/connection/websocket
CENTRIFUGO_API_KEY=your-key
CENTRIFUGO_TOKEN_HMAC_SECRET=your-secret

# ─── Perplexity (Web Search — Optional) ───
PERPLEXITY_API_KEY=pplx-your-key

# ─── Jina (Web Content Retrieval — Optional) ───
JINA_API_KEY=jina_your-key

# ─── Redis (Stream Resumption — Optional) ───
REDIS_URL=redis://localhost:6379

# ─── Vercel ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
